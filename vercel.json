{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "python -m pip install -r requirements.txt",
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "api/asgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/asgi.py"
    }
  ]
}
